{
  "name": "ai-callcenter-service",
  "image": "your-dockerhub-username/ai-callcenter-service:latest",
  "gpu": {
    "type": "NVIDIA RTX A4000",
    "count": 1
  },
  "ports": {
    "8000": "HTTP"
  },
  "environment": {
    "WHISPER_MODEL": "medium",
    "DEVICE": "cuda",
    "SENTIMENT_MODEL": "distilbert-base-uncased-finetuned-sst-2-english",
    "SPACY_MODEL": "en_core_web_sm",
    "SUMMARIZATION_MODEL": "facebook/bart-large-cnn"
  },
  "resources": {
    "cpu": 4,
    "memory": 16,
    "disk": 50
  },
  "scaling": {
    "min_instances": 0,
    "max_instances": 3,
    "idle_timeout": 300
  }
}
