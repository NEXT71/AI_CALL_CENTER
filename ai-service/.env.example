# AI Service Configuration
PORT=8000
HOST=0.0.0.0

# CORS Configuration (comma-separated allowed origins)
# Local development:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
# Render deployment:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://ai-callcenter-backend.onrender.com
# RunPod deployment:
# ALLOWED_ORIGINS=http://localhost:5000,https://*.proxy.runpod.net

# Whisper Model (tiny, base, small, medium, large)
# Render (2GB RAM): Use 'base' model
# RunPod RTX A4500 (20GB VRAM): Can handle 'medium' or 'large'
WHISPER_MODEL=base

# Device (cpu, cuda)
# Render: Use 'cpu' (no GPU available)
# RunPod: Use 'cuda' (GPU-enabled)
DEVICE=cpu

# Performance Settings
# Number of concurrent processing workers
MAX_WORKERS=3

# NLP Models (all FREE & open-source)
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
SPACY_MODEL=en_core_web_sm
SUMMARIZATION_MODEL=facebook/bart-large-cnn

# Speaker Diarization (pyannote.audio)
# Requires HuggingFace token for model download (free account)
# Get token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
