{
  "apps": [
    {
      "name": "ai-service",
      "script": "main.py",
      "cwd": "/workspace/AI_CALL_CENTER/ai-service",
      "interpreter": "python3",
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "4G",
      "env": {
        "PYTHONUNBUFFERED": "1",
        "CUDA_VISIBLE_DEVICES": "0"
      },
      "error_file": "/workspace/logs/ai-service-error.log",
      "out_file": "/workspace/logs/ai-service-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true
    },
    {
      "name": "backend-api",
      "script": "src/server.js",
      "cwd": "/workspace/AI_CALL_CENTER/backend",
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "1G",
      "env": {
        "NODE_ENV": "production"
      },
      "error_file": "/workspace/logs/backend-error.log",
      "out_file": "/workspace/logs/backend-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true
    },
    {
      "name": "call-worker",
      "script": "src/workers/callProcessor.js",
      "cwd": "/workspace/AI_CALL_CENTER/backend",
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "1G",
      "env": {
        "NODE_ENV": "production",
        "WORKER_ID": "runpod-worker-1"
      },
      "error_file": "/workspace/logs/worker-error.log",
      "out_file": "/workspace/logs/worker-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true
    }
  ]
}
