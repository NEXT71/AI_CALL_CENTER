# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# Get your MongoDB Atlas connection string from https://cloud.mongodb.com
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/your_database_name

# JWT Configuration - CHANGE THESE IN PRODUCTION!
# Generate secure random strings: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# AI Service
# Local development:
AI_SERVICE_URL=http://localhost:8000
# Render deployment:
# AI_SERVICE_URL=https://ai-callcenter-ai-service.onrender.com
# RunPod deployment:
# AI_SERVICE_URL=https://your-pod-id-8000.proxy.runpod.net

# CORS Allowed Origins (comma-separated)
# Local development:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Render + Vercel deployment:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://ai-callcenter-backend.onrender.com

# Upload Configuration
UPLOAD_DIR=./uploads/calls
MAX_FILE_SIZE=104857600

# Redis Configuration (for job queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Worker Configuration
# RunPod RTX A4500 (20GB VRAM) can handle 3 concurrent processes
WORKER_CONCURRENCY=3

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# File Cleanup Job
FILE_RETENTION_DAYS=30
