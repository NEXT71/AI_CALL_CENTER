# Server Configuration
PORT=5000
NODE_ENV=development

# Payment Mode (stripe or manual)
PAYMENT_MODE=manual

# MongoDB Configuration
# Get your MongoDB Atlas connection string from https://cloud.mongodb.com
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/your_database_name

# JWT Configuration - CHANGE THESE IN PRODUCTION!
# Generate secure random strings: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# AI Service
# Local development:
AI_SERVICE_URL=http://localhost:8000
# Render deployment:
# AI_SERVICE_URL=https://ai-callcenter-ai-service.onrender.com
# RunPod deployment:
# AI_SERVICE_URL=https://your-pod-id-8000.proxy.runpod.net

# CORS Allowed Origins (comma-separated)
# Local development:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Render + Vercel deployment:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://ai-callcenter-backend.onrender.com

# Upload Configuration
UPLOAD_DIR=./uploads/calls
MAX_FILE_SIZE=104857600

# Redis Configuration (for job queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Worker Configuration
# RunPod RTX A4500 (20GB VRAM) can handle 3 concurrent processes
WORKER_CONCURRENCY=3

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# File Cleanup Job
FILE_RETENTION_DAYS=30

# Stripe Payment Configuration
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create products in Stripe dashboard)
STRIPE_STARTER_PRICE_ID=price_starter_plan_id
STRIPE_PROFESSIONAL_PRICE_ID=price_professional_plan_id
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_plan_id

# Email Configuration (for verification and notifications)
# For Gmail: Enable "Less secure app access" or use App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL (for email links and redirects)
FRONTEND_URL=http://localhost:3000

# RunPod Configuration (for GPU pod control)
# Get your API key from: https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=your_runpod_api_key_here
# Get Pod ID from: https://www.runpod.io/console/pods (it's the ID of your deployed pod)
RUNPOD_POD_ID=your_pod_id_here

# HuggingFace Token (for diarization models)
# Get token from: https://huggingface.co/settings/tokens
# Required to accept: https://huggingface.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=your_huggingface_token_here
